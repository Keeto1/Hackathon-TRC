# OpenRouter API Configuration (Optional - uses free models)
# Get your FREE API key from: https://openrouter.ai (sign up and create API key)
# This app now routes AI calls through a server-side endpoint, so the key should be set in OPENROUTER_API_KEY.
# If you set NEXT_PUBLIC_OPENROUTER_API_KEY it will still work, but it will be exposed to the browser.
OPENROUTER_API_KEY=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
# Optional: override the OpenRouter model ID (defaults to a free Llama 3 model)
 
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# Future: Database Configuration (Optional)
# DATABASE_URL=your_database_url
# DATABASE_API_KEY=your_api_key

# Future: Supabase Configuration (Optional)
# NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
