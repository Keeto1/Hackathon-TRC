# Environment Variables for Campus AI Buddy

# OpenRouter API Configuration (Required for AI chat)
# Get your FREE API key from: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional OpenRouter settings
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_MAX_TOKENS=2048
OPENROUTER_MAX_MESSAGES=25
OPENROUTER_MAX_WORDS=100

# DeepSeek API Configuration (Required for conversation titles)
# Get your API key from DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Future: Database Configuration (Optional)
# DATABASE_URL=your_database_url
# DATABASE_API_KEY=your_api_key

# Future: Supabase Configuration (Optional)
# NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
